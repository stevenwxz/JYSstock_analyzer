<!--pages/history/history.wxml-->
<view class="container">
  <view class="section-title">
    <text class="title-text">📅 历史分析记录</text>
    <text class="title-desc">查看过往选股结果</text>
  </view>

  <!-- 历史记录列表 -->
  <view class="history-list">
    <view
      class="history-item card"
      wx:for="{{historyList}}"
      wx:key="date"
      bindtap="onHistoryTap"
      data-filename="{{item.filename}}"
    >
      <view class="history-header">
        <text class="history-date">{{item.date}}</text>
        <text class="history-count">推荐{{item.stockCount}}只</text>
      </view>

      <view class="history-detail">
        <text class="top-stock-label">首推股票:</text>
        <text class="top-stock-name">{{item.topStock || '无'}}</text>
      </view>

      <!-- 点击提示 -->
      <view class="tap-hint">
        <text>点击查看详情 ></text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && historyList.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无历史记录</view>
  </view>
</view>
