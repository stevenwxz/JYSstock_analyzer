/* pages/history/history.wxss */

.history-list {
  margin-bottom: 20rpx;
}

.history-item {
  margin-bottom: 24rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.history-count {
  font-size: 26rpx;
  color: #1aad19;
  background-color: #f0f9ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.history-detail {
  display: flex;
  align-items: center;
}

.top-stock-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 12rpx;
}

.top-stock-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

/* 点击提示 */
.tap-hint {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
}

.tap-hint text {
  font-size: 24rpx;
  color: #1aad19;
}

/* 点击效果 */
.history-item {
  transition: transform 0.2s;
}

.history-item:active {
  transform: scale(0.98);
  background-color: #f5f5f5;
}
