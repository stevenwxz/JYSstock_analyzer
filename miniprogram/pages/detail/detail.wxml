<!--pages/detail/detail.wxml-->
<view class="container">
  <view wx:if="{{stock}}">
    <!-- 股票头部信息 -->
    <view class="card stock-header-card">
      <view class="stock-title">
        <text class="stock-name">{{stock.name}}</text>
        <text class="stock-code">{{stock.code}}</text>
      </view>

      <view class="stock-price-info">
        <view class="price-main">
          <text class="current-price">¥{{stock.price}}</text>
          <view class="price-change {{stock.changePct >= 0 ? 'price-up' : 'price-down'}}">
            <text class="change-amount">{{stock.changeAmount >= 0 ? '+' : ''}}{{stock.changeAmount}}</text>
            <text class="change-pct">{{stock.changePct >= 0 ? '+' : ''}}{{stock.changePct}}%</text>
          </view>
        </view>

        <view class="price-range">
          <view class="range-item">
            <text class="range-label">今开</text>
            <text class="range-value">{{stock.open}}</text>
          </view>
          <view class="range-item">
            <text class="range-label">昨收</text>
            <text class="range-value">{{stock.previousClose}}</text>
          </view>
          <view class="range-item">
            <text class="range-label">最高</text>
            <text class="range-value price-up">{{stock.high}}</text>
          </view>
          <view class="range-item">
            <text class="range-label">最低</text>
            <text class="range-value price-down">{{stock.low}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 成交量信息 -->
    <view class="card">
      <view class="section-header">
        <text class="section-title">成交信息</text>
      </view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">成交量</text>
          <text class="info-value">{{stock.volume}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">成交额</text>
          <text class="info-value">{{stock.turnover}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">换手率</text>
          <text class="info-value">{{stock.turnoverRate}}%</text>
        </view>
      </view>
    </view>

    <!-- 估值指标 -->
    <view class="card">
      <view class="section-header">
        <text class="section-title">估值指标</text>
      </view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">市盈率(PE)</text>
          <text class="info-value">{{stock.peRatio}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">市净率(PB)</text>
          <text class="info-value">{{stock.pbRatio}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn-primary" bindtap="onRefresh">刷新数据</button>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !stock}}">
    <view class="empty-icon">⚠️</view>
    <view class="empty-text">股票信息加载失败</view>
    <button class="btn-secondary" bindtap="onRefresh">重新加载</button>
  </view>
</view>
