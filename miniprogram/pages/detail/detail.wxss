/* pages/detail/detail.wxss */

.stock-header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.stock-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.stock-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.stock-code {
  font-size: 28rpx;
  opacity: 0.8;
}

.stock-price-info {
  display: flex;
  flex-direction: column;
}

.price-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.current-price {
  font-size: 56rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.price-change {
  display: flex;
  align-items: baseline;
}

.change-amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.change-pct {
  font-size: 28rpx;
}

.price-range {
  display: flex;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.range-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.range-label {
  font-size: 22rpx;
  opacity: 0.7;
  margin-bottom: 8rpx;
}

.range-value {
  font-size: 28rpx;
  font-weight: bold;
}

/* 区块标题 */
.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}
