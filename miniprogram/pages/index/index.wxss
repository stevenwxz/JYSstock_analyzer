/* pages/index/index.wxss */

/* 市场概览 */
.market-overview {
  margin-bottom: 30rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.overview-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 区块标题 */
.section-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.title-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 股票列表 */
.stock-list {
  margin-bottom: 20rpx;
}

.stock-item {
  position: relative;
  margin-bottom: 24rpx;
}

/* 排名标识 */
.rank-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.rank-badge.rank-1 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.rank-badge.rank-2 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.rank-badge.rank-3 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

/* 股票头部 */
.stock-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.stock-name-section {
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stock-code {
  font-size: 24rpx;
  color: #999999;
}

.stock-price-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stock-change {
  font-size: 28rpx;
  font-weight: bold;
}

/* 评分区域 */
.stock-score {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.score-main {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.score-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.grade-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background-color: #fff;
}

.score-breakdown {
  display: flex;
  justify-content: space-around;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-item-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.score-item-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 关键指标 */
.stock-indicators {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.indicator-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.indicator-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.indicator-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 推荐理由 */
.stock-reason {
  display: flex;
  align-items: flex-start;
  background-color: #fffbe6;
  border-left: 4rpx solid #faad14;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.reason-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.reason-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 行业标签 */
.industry-tag {
  display: inline-block;
  background-color: #e6f7ff;
  color: #1890ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 更新时间 */
.update-time {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 评级颜色覆盖 */
.grade-a-plus,
.grade-A-plus,
.grade-aplus {
  color: #ff4d4f;
}

.grade-a,
.grade-A {
  color: #ff7a45;
}

.grade-b-plus,
.grade-B-plus,
.grade-bplus,
.grade-b,
.grade-B {
  color: #ffa940;
}

.grade-c,
.grade-C {
  color: #faad14;
}
